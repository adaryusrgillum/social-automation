<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.socialautomation">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Additional permissions as needed for WorkManager or AccessibilityService -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Social Automation"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.DayNight">
        
        <receiver android:name=".PostReceiver" android:exported="true">
            <intent-filter>
                <action android:name="com.socialautomation.EXECUTE_POST" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
